{% extends 'base.html.twig' %}

{#
   Editorial browse grid for NomNom. Photo-free, type-led cards.
   Requires DM Serif Display + Spectral (base.html.twig) and the
   .recipe-index styles in editorial.css.
#}

{% block body %}
    <div class="recipe-index">

        <div class="re-index-top">
            <span>Alle Rezepte</span>
            <span class="re-issue">{{ recipes|length }} {{ recipes|length == 1 ? 'Rezept' : 'Rezepte' }}</span>
        </div>

        <h1 class="re-index-title">Unsere Familienküche</h1>

        <div class="re-grid">
            {% for recipe in recipes %}
                {% set excerpt = recipe.description|length > 160
                    ? recipe.description|slice(0, 160)|trim ~ '…'
                    : recipe.description %}
                <div class="re-card">
                    <div class="re-card-hero-image">
                        {% if recipe.image and (recipe.image starts with '/' or remote_file_exists(recipe.image)) %}
                            <img src="{{ recipe.image }}" alt="Bild des Rezepts" class="re-card-image">
                        {% else %}
                            <div class="re-card-placeholder"></div>
                        {% endif %}
                    </div>
                    <div class="re-card-kicker">
                        <span>von {{ recipe.user.username|default('Unbekannt') }}</span>
                        {% if recipe.ingredients|length %}
                            <span class="re-k-dot">·</span>
                            <span class="re-k-sub">{{ recipe.ingredients|length }} 
                                {{ recipe.ingredients|length == 1 ? 'Zutat' : 'Zutaten' }}
                            </span>
                        {% endif %}
                    </div>
                    <h2 class="re-card-title">{{ recipe.name }}</h2>
                    <p class="re-card-excerpt">{{ excerpt }}</p>
                    <div class="re-card-foot">
                        <button type="button" class="re-card-link"
                                onclick="window.location.href='/rezept/{{ recipe.id }}/'">
                            Zum Rezept →
                        </button>
                    </div>
                </div>
            {% else %}
                <p class="re-empty">Keine Rezepte gefunden.</p>
            {% endfor %}
        </div>

    </div>
{% endblock %}
