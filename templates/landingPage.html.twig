{% extends 'base.html.twig' %}

{#
   Landing page — "Rezept des Tages".
   A teaser tile, not the full recipe: full-bleed hero photo, title,
   meta and description only. Ingredients + preparation live on the
   recipe page (viewRecipe), reached via the "Zum Rezept" button.
   Requires DM Serif Display + Spectral (base.html.twig) and editorial.css.
#}

{% block body %}
    <div class="recipe-editorial recipe-editorial--landing">

        <div class="re-top re-top--actions">
            <span class="re-kicker">Rezept</span>
            <div class="re-top-actions">
            </div>
        </div>

        {% if recipe.image %}
            <div class="re-image">
                <img src="{{ recipe.image }}" alt="{{ recipe.name }}">
            </div>
        {% endif %}

        <div class="re-head re-head--solo">
            <h1 class="re-title">{{ recipe.name }}</h1>
            <div class="re-meta">
                <span>von {{ recipe.user.username|default('Unbekannt') }}</span>
                {% if recipe.ingredients|length %}
                    <span class="re-dot">·</span>
                    <span>{{ recipe.ingredients|length }} Zutaten</span>
                {% endif %}
            </div>
        </div>

        {% if recipe.description %}
            <p class="re-lede">{{ recipe.description }}</p>
        {% endif %}

        <div class="re-readmore">
            <p class="re-readmore-note">Zutaten &amp; Zubereitung im vollständigen Rezept</p>
            <button type="button" class="re-cta"
                    onclick="window.location.href='/rezept/{{ recipe.id }}/'">
                Zum Rezept →
            </button>
        </div>

        <div class="re-foot">
            <span>NomNom</span>
            <span>Guten Appetit</span>
        </div>

    </div>
{% endblock %}
