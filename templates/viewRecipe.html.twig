{% extends 'base.html.twig' %}

{% block body %}
    <h1></h1>
    <div class="recipe-container tile">
        <div class="header-area">
        <h2>{{ recipe.name }}</h2>
            <div class="buttons">
                <button class="btn primary" onclick="window.location.href='/rezept/{{ recipe.id }}/bearbeiten'">Rezept bearbeiten</button>
            </div>
        </div>
        
        <div class="recipe-description">
            <p>{{ recipe.description }}</p>
        </div>

        <div class="recipe-image">
            <img src="{{ recipe.image }}" alt="Bild des Rezepts" class="recipe-image" id="recipe-image">
        </div>
        <div class="recipe-ingredients">
        <h3>Zutaten</h3>
            <ul>
                {% for ingredient in recipe.ingredients %}
                    <li>{{ ingredient.amount }} {{ ingredient.unit }} {{ ingredient.name }}</li>
                {% endfor %}
            </ul>
        </div>
        <div class="recipe-instructions">
            <h3>Zubereitung</h3>
            <p>{{ recipe.instructions }}</p>
        </div>
    </div>
{% endblock %}